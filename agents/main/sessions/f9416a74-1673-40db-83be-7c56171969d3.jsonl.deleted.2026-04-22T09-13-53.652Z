hu/.npm-global/lib/node_modules/agent-browser\n/Users/zhu/.npm-global/lib/node_modules/agent-browser/bin/agent-browser-linux-x64\n/Users/zhu/.npm-global/lib/node_modules/agent-browser/bin/agent-browser-darwin-x64\n/Users/zhu/.npm-global/lib/node_modules/agent-browser/bin/agent-browser-win32-x64.exe\n/Users/zhu/.npm-global/lib/node_modules/agent-browser/bin/agent-browser.js\n/Users/zhu/.npm-global/lib/node_modules/agent-browser/bin/agent-browser-darwin-arm64\n/Users/zhu/.npm-global/lib/node_modules/agent-browser/bin/agent-browser-linux-arm64\n/Users/zhu/.npm-global/lib/node_modules/agent-browser/bin/agent-browser-linux-musl-arm64\n/Users/zhu/.npm-global/lib/node_modules/agent-browser/bin/agent-browser-linux-musl-x64\n/Users/zhu/.npm-global/lib/node_modules/agent-browser/skills/agent-browser\n/Users/zhu/.npm-global/lib/node_modules/openclaw/dist/browser-profiles-j3ZUhu4j.js\n/Users/zhu/.npm-global/lib/node_modules/openclaw/dist/browser-config-support-DeTP2_70.js\n/Users/zhu/.npm-global/lib/node_modules/openclaw/dist/browser-open-DTnf-7Tf.js\n/Users/zhu/.npm-global/lib/node_modules/openclaw/dist/browser-control-auth-Z8h43aQW.js\n/Users/zhu/.npm-global/lib/node_modules/openclaw/dist/browser-config-runtime-Db5LKdcQ.js\n/Users/zhu/.npm-global/lib/node_modules/openclaw/dist/browser-runtime-BNxd-J_h.js\n/Users/zhu/.npm-global/lib/node_modules/openclaw/dist/plugin-sdk/browser-security-runtime.d.ts\n/Users/zhu/.npm-global/lib/node_modules/openclaw/dist/plugin-sdk/browser-setup-tools.d.ts\n/Users/zhu/.npm-global/lib/node_modules/openclaw/dist/plugin-sdk/browser-config-support.d.ts","cwd":"/Users/zhu/.openclaw/workspace"},"isError":false,"timestamp":1776836121735}}
